generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  GESTOR
  USER
}

model User {
  id       BigInt @id
  email    String @unique
  password String
  name     String
  role     Role   @default(USER)
}
